# ── RSLI Backend Environment Variables ──
# Copy to `.env` for local development or set in Azure App Service Configuration.
# Never commit real secrets/keys to Git.

# ── LLM Configuration ──
# Provider order preference (comma-separated, e.g., google,azure)
LLM_PROVIDER_ORDER=google
# Whether to fall back to the next provider if the primary one fails (true/false)
LLM_FAILOVER=true

# ── Google Generative AI ──
# API key for Gemini models
GEMINI_API_KEY=
# Model name to target for text generation / column narrative generation
GEMINI_MODEL=gemini-1.5-flash

# ── Azure OpenAI / OpenAI-compatible ──
# API key for OpenAI
OPENAI_API_KEY=
# Base URL for API requests (e.g. Azure OpenAI endpoints)
OPENAI_BASE_URL=
# Model name to target
OPENAI_MODEL=

# ── Enterprise Governance & Security ──
# Secret key used for signing JWT cookies (Change this in production!)
RSLI_SECRET_KEY=dev-secret-key-change-me
# Initial admin user email (seeded automatically if database is new)
RSLI_ADMIN_EMAIL=admin@acme.com
# Invitation code required during user registration
RSLI_INVITE_CODE=ACME2026
# Database Connection URL (SQLite or PostgreSQL)
RSLI_DATABASE_URL=sqlite:///rsli.db

# ── Azure Blob Storage Integration ──
# Connection string for Azure Blob Storage. If set, uploads and execution results 
# will be archived to Azure Blob Storage and deleted locally.
AZURE_STORAGE_CONNECTION_STRING=

# ── API & CORS Configuration ──
# Comma-separated list of origins allowed to make CORS calls
RSLI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Seconds before local session temp directories are cleaned up (default: 1800)
RSLI_SESSION_CLEANUP_S=1800

# ── PII Sanitizer & Sensitive Columns ──
# Additional comma-separated column names to flag as sensitive/PII for masking
RSLI_SENSITIVE_COLUMNS=
