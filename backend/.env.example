# Copy to `.env` on Azure App Service (Configuration → Application settings) or local file.
# Never commit real secrets to git.

# Comma-separated browser origins allowed to call this API (CORS).
# Required when the SPA is hosted separately, e.g. Azure Storage static website:
#   RSLI_CORS_ORIGINS=https://yourstorage.z20.web.core.windows.net,https://your-app.azurewebsites.net
RSLI_CORS_ORIGINS=

# Seconds before temp upload/output workspace is deleted (default 1800).
# RSLI_SESSION_CLEANUP_S=1800
